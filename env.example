# ─────────────────────────────────────────────────────────────
# .env.example  –  MockMentor Environment Variables
# ─────────────────────────────────────────────────────────────
# COPY this file to .env and fill in your values.
# .env is loaded automatically by config.py (python-dotenv).
# NEVER commit the real .env to git.
# ─────────────────────────────────────────────────────────────

# ── Flask environment ──────────────────────────────────────────
# "development" → DevelopmentConfig (debug on, local uploads)
# "production"  → ProductionConfig  (debug off, secure cookies)
FLASK_ENV=development

# ── Secret key ────────────────────────────────────────────────
# Generate a strong key:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-real-secret-key

# ── Local MySQL (XAMPP / local install) ───────────────────────
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=mockmentor_db
MYSQL_PORT=3306

# ── Managed / cloud MySQL (uncomment and fill when deploying) ──
# MYSQL_HOST=your-db-host.example.com
# MYSQL_USER=mockmentor_user
# MYSQL_PASSWORD=your-db-password
# MYSQL_DB=mockmentor_db
# MYSQL_PORT=3306
# MYSQL_SSL=1          # Required for PlanetScale, Aiven, TiDB

# ── Upload folder ─────────────────────────────────────────────
# Local dev:   static/uploads    (relative to project root)
# Cloud/prod:  /tmp/mockmentor_uploads  (auto-set by ProductionConfig)
# UPLOAD_FOLDER=/tmp/mockmentor_uploads

# ── Port (Cloud Run / Railway set this automatically) ─────────
# PORT=5000
